{
  "expo": {
    "name": "Board Game Library",
    "slug": "board-game-library",
    "version": "1.19.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "bgl",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-secure-store",
      "expo-sharing",
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ballewcifer.boardgamelibrary"
    },
    "android": {
      "package": "com.ballewcifer.boardgamelibrary",
      "allowBackup": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a237e"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "133eae39-15da-488e-ae37-9167e7bd84d3"
      }
    }
  }
}
